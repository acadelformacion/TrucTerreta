{
  "rules": {
    "rooms": {
      ".read": true,
      "$room": {
        ".write": "auth != null"
      }
    },
    "userMeta": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "nicknames": {
      "$nick": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || data.child('reservedUntil').val() < now)"
      }
    },
    "secret_hands": {
      "$room": {
        "hands": {
          "$seat": {
            ".read": "auth != null && (root.child('rooms/'+$room+'/state/players/'+$seat+'/uid').val() === auth.uid || (root.child('rooms/'+$room+'/state/players/'+$seat+'/guest').val() === true && root.child('rooms/'+$room+'/state/players/_0/uid').val() === auth.uid))",
            ".write": false
          }
        },
        "envitPoints": {
          "$seat": {
            ".read": "auth != null && (root.child('rooms/'+$room+'/state/players/'+$seat+'/uid').val() === auth.uid || (root.child('rooms/'+$room+'/state/players/'+$seat+'/guest').val() === true && root.child('rooms/'+$room+'/state/players/_0/uid').val() === auth.uid))",
            ".write": false
          }
        }
      }
    }
  }
}
